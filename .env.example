# GROQ_API_KEY: Used by AI Chat (Groq provider) and Market News AI enrichment.
# Get a free key at https://console.groq.com
# In production (AWS), set GROQ_SECRET_NAME instead (defaults to "fintrace/groq-api-key")
# and ensure the Lambda/ECS role has secretsmanager:GetSecretValue permission.
GROQ_API_KEY="gsk_..."

# AWS_REGION: Set this in production to enable AWS Secrets Manager key lookup.
# AWS_REGION="ap-southeast-1"
# GROQ_SECRET_NAME="fintrace/groq-api-key"

# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# OPENROUTER_FALLBACK_API_KEY: Fallback key used by FinTrace when the user has not entered an OpenRouter key.
# This key is only used server-side via the /api/openrouter proxy routes.
# In production (AWS), set OPENROUTER_SECRET_NAME instead (defaults to "fintrace/openrouter-api-key").
OPENROUTER_FALLBACK_API_KEY="MY_OPENROUTER_FALLBACK_API_KEY"
# OPENROUTER_SECRET_NAME="fintrace/openrouter-api-key"

# HUGGINGFACE_FALLBACK_API_KEY: Fallback key used by FinTrace when the user has not entered a Hugging Face token.
# This key is only used server-side via the /api/huggingface proxy routes.
# In production (AWS), set HUGGINGFACE_SECRET_NAME instead (defaults to "fintrace/huggingface-api-key").
HUGGINGFACE_FALLBACK_API_KEY="MY_HUGGINGFACE_FALLBACK_API_KEY"
# HUGGINGFACE_SECRET_NAME="fintrace/huggingface-api-key"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# NEXT_PUBLIC_STOCK_LAMBDA_URL: Public Lambda URL used by stock universe to fetch listing + light chart data.
# Do not hard-code in source; configure here per environment.
NEXT_PUBLIC_STOCK_LAMBDA_URL="https://your-stock-lambda-url.lambda-url.ap-southeast-1.on.aws"

# Optional tuning for stock universe fetch size/performance
# NEXT_PUBLIC_STOCK_LIST_LIMIT="450"
# NEXT_PUBLIC_STOCK_HISTORY_CONCURRENCY="16"

# DNSE OpenAPI credentials for Market Data WebSocket (server-side only).
# Used by /api/dnse/realtime/stream with auth message over ws-openapi.
# Never expose these in NEXT_PUBLIC_* variables.
DNSE_API_KEY="your_dnse_api_key"
DNSE_API_SECRET="your_dnse_api_secret"

# REDIS_URL: Server-only — bật trang /redis (xem dữ liệu Redis qua API).
# Trong Docker Compose thường dùng host `redis`. Máy local: `127.0.0.1` hoặc tunnel SSH.
# Định dạng: redis://:PASSWORD@HOST:6379  (một ký tự @ trước hostname)
# REDIS_URL="redis://:changeme@127.0.0.1:6379"
# REDIS_BROWSE_PAGE_SIZE="250"

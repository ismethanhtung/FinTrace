{
    "name": "react-example",
    "private": true,
    "version": "0.0.0",
    "type": "module",
    "scripts": {
        "dev": "next dev -p 3000 --turbo",
        "build": "next build",
        "start": "next start -p 3000",
        "lint": "tsc --noEmit",
        "typecheck": "tsc --noEmit",
        "test": "vitest run --project unit",
        "test:watch": "vitest --project unit",
        "test:coverage": "vitest run --coverage",
        "test:coverage:unit": "vitest run --project unit --coverage",
        "test:coverage:gate": "npm run test:coverage && node ./scripts/check-coverage-threshold.mjs",
        "test:integration": "vitest run --project integration",
        "test:contract": "vitest run --project contract",
        "test:perf": "vitest run --project perf",
        "test:e2e": "vitest run --project e2e",
        "test:all": "npm run test && npm run test:integration && npm run test:contract && npm run test:perf && npm run test:e2e",
        "security:audit": "npm audit --audit-level=high",
        "security:secrets": "node ./scripts/check-secrets.mjs"
    },
    "dependencies": {
        "@aws-sdk/client-secrets-manager": "^3.1015.0",
        "@google/genai": "^1.29.0",
        "@opennextjs/cloudflare": "^1.18.0",
        "@tailwindcss/vite": "^4.1.14",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "@vitejs/plugin-react": "^5.0.4",
        "clsx": "^2.1.1",
        "date-fns": "^4.1.0",
        "dotenv": "^17.2.3",
        "express": "^4.21.2",
        "ioredis": "^5.10.1",
        "lightweight-charts": "^5.1.0",
        "lucide-react": "^0.546.0",
        "motion": "^12.23.24",
        "next": "^16.2.0",
        "react": "^19.0.0",
        "react-dom": "^19.0.0",
        "react-markdown": "^10.1.0",
        "recharts": "^3.8.0",
        "rss-parser": "^3.13.0",
        "tailwind-merge": "^3.5.0",
        "vite": "^6.2.0",
        "ws": "^8.18.0"
    },
    "devDependencies": {
        "@tailwindcss/postcss": "^4.2.2",
        "@testing-library/react": "^16.3.2",
        "@types/express": "^4.17.21",
        "@types/node": "^22.14.0",
        "@types/ws": "^8.5.14",
        "@vitest/coverage-v8": "^4.1.2",
        "autoprefixer": "^10.4.21",
        "jsdom": "^26.1.0",
        "playwright": "^1.54.2",
        "tailwindcss": "^4.1.14",
        "tsx": "^4.21.0",
        "typescript": "~5.8.2",
        "vite": "^6.2.0",
        "vitest": "^4.1.2"
    }
}
